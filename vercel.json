{
  "cleanUrls": true,
  "functions": {
    "api/index.ts": {
      "maxDuration": 25,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!assets/|Innobyte-Logo.png|favicon.ico|manifest.json).*)", "destination": "/index.html" }
  ]
}
