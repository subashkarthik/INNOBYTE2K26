# ─── Email (Resend) ────────────────────────────────────────────────────────────
# 1. Go to https://resend.com → Sign up (free)
# 2. Dashboard → API Keys → Create API Key → copy it below
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Who sends the email:
#   Free/testing: keep as "onboarding@resend.dev" (works immediately, no setup)
#   Production:   verify your domain at resend.com and use "noreply@yourdomain.com"
FROM_EMAIL="onboarding@resend.dev"

# Your email — admin notification goes here on every registration
ADMIN_EMAIL="your-email@gmail.com"

# ─── Google Sheets (SheetDB) ───────────────────────────────────────────────────
# 1. Create a Google Sheet (add any headers you want in row 1)
# 2. Go to https://sheetdb.io → Sign in with Google → Add new API
# 3. Paste your Sheet URL → Create → Copy the full API URL below
SHEETDB_URL="https://sheetdb.io/api/v1/your-api-id-here"

# ─── Optional ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
